# ── WealthLens MX — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git!

# ── AI Gateway (Required for AI features) ──────────────────────────────────────
# Get a free Groq API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# AI model to use (LLaMA 3.3 70B is fast and free on Groq)
AI_MODEL=llama-3.3-70b-versatile

# AI endpoint — change this to switch providers (DeepSeek, Ollama, OpenRouter)
AI_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# ── Optional: DeepSeek (cheaper for high volume) ───────────────────────────────
# DEEPSEEK_API_KEY=your_deepseek_key_here
# AI_BASE_URL=https://api.deepseek.com/v1/chat/completions
# AI_MODEL=deepseek-chat

# ── Optional: Local Ollama (fully offline, free) ───────────────────────────────
# AI_BASE_URL=http://localhost:11434/v1/chat/completions
# AI_MODEL=llama3.3

# ── Flask Security ─────────────────────────────────────────────────────────────
# Change this to a long random string in production!
SECRET_KEY=change-me-to-a-long-random-string-in-production
